# Postgres credentials
POSTGRES_USER=represa
POSTGRES_PASSWORD=represa_dev
POSTGRES_DB=represa

# Service ports (host-exposed)
ENGINE_PORT=8001
API_PORT=8000
FRONTEND_PORT=8080

# Database connection (used by backend-api)
DATABASE_URL=postgresql+asyncpg://represa:represa_dev@postgres:5432/represa

# Internal service URLs (container-to-container via docker network)
ENGINE_INTERNAL_URL=http://simulation-engine:8001
API_INTERNAL_URL=http://backend-api:8000
